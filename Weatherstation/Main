#include <WiFi.h>
#include <PubSubClient.h>
#include <Wire.h>
#include <Adafruit_BME280.h>

// WLAN Zugangsdaten
String wifi_ssid = "Schwetlick";
String wifi_pass = "Ab130971";

// MQTT Server
const char* mqtt_server = "192.168.2.50";
const int mqtt_port = 1883;

// MQTT Client
WiFiClient espClient;
PubSubClient client(espClient);

// BME280 Sensor
Adafruit_BME280 bme;
bool bme_ok = false;

// WLAN verbinden
void setup_wifi() {
  delay(100);

  WiFi.begin(wifi_ssid.c_str(), wifi_pass.c_str());

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }
}

// MQTT reconnect
void reconnect() {
  while (!client.connected()) {
    if (client.connect("ESP32_BME280")) {
      // verbunden
    } else {
      delay(2000);
    }
  }
}

void setup() {
  Serial.begin(115200);

  setup_wifi();

  client.setServer(mqtt_server, mqtt_port);

  // BME280 starten
  if (bme.begin(0x76)) {
    bme_ok = true;
  } else {
    bme_ok = false;
  }
}

void loop() {
  if (!client.connected()) {
    reconnect();
  }
  client.loop();

  if (bme_ok) {
    float temp = bme.readTemperature();
    float hum = bme.readHumidity();
    float pres = bme.readPressure() / 100.0F;

    // JSON String bauen
    String payload = "{";
    payload += "\"temperature\":" + String(temp, 1) + ",";
    payload += "\"humidity\":" + String(hum, 1) + ",";
    payload += "\"pressure\":" + String(pres, 1);
    payload += "}";

    client.publish("esp32/bme280", payload.c_str());
  }

  delay(5000);
}